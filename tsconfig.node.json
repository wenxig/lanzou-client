{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "allowSyntheticDefaultImports": true,
    "noImplicitReturns": false,
    "noImplicitAny": true,
    "noImplicitOverride": true,
    "noImplicitThis": true,
  },
  "include": [
    "vite.config.mts",
    ".releaserc.mjs",
    "commitlint.config.ts",
    "script/*"
  ]
}